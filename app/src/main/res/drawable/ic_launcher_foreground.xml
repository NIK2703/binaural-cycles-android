    <!-- arc=160° < 180°, large-arc=0 -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M30,54 A24,24 0 0 1 76.56,45.79"/>
    
    <!-- Lower arc: from right end (0°) to 160° through BOTTOM (90°) -->
    <!-- sweep=1 (clockwise): 0° → 90° → 160° through BOTTOM -->
    <!-- arc=160° < 180°, large-arc=0 -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M78,54 A24,24 0 0 1 31.44,62.21"/>
    
